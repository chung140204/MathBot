generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  password     String
  name         String
  role         UserRole      @default(STUDENT)
  isLocked     Boolean       @default(false)
  createdAt    DateTime      @default(now())
  grade        String?
  targetScore  String?
  image        String?
  settings     Json?         @default("{}")
  updatedAt    DateTime      @updatedAt
  chatSessions  ChatSession[]
  examAttempts  ExamAttempt[]
  studyProgress StudyProgress[]

  @@map("users")
}

model Question {
  id                 String         @id @default(cuid())
  content            String
  options            Json
  answer             String
  explanation        String
  topic              Topic
  difficulty         Difficulty
  isActive           Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  answerA            Boolean?
  answerB            Boolean?
  answerC            Boolean?
  answerD            Boolean?
  correctAnswer      String?
  format             QuestionFormat @default(MULTIPLE_CHOICE)
  statementA         String?
  statementB         String?
  statementC         String?
  statementD         String?
  imageUrl           String?
  optionAImageUrl    String?
  optionBImageUrl    String?
  optionCImageUrl    String?
  optionDImageUrl    String?
  questionType       QuestionType   @default(PRACTICE)
  statementAImageUrl String?
  statementBImageUrl String?
  statementCImageUrl String?
  statementDImageUrl String?
  examAnswers        ExamAnswer[]

  @@index([topic, difficulty, isActive])
  @@map("questions")
}

model ExamAttempt {
  id             String       @id @default(cuid())
  userId         String
  totalScore     Float
  totalQuestions Int
  timeTakenSecs  Int
  topics         Topic[]
  mode           ExamMode     @default(STANDARD)
  startedAt      DateTime     @default(now())
  submittedAt    DateTime     @default(now())
  answers        ExamAnswer[]
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, submittedAt])
  @@map("exam_attempts")
}

model ExamAnswer {
  id            String      @id @default(cuid())
  examAttemptId String
  questionId    String
  userAnswer    String?
  isCorrect     Boolean
  score         Float       @default(0)
  shortAnswer   String?
  tfAnswerA     Boolean?
  tfAnswerB     Boolean?
  tfAnswerC     Boolean?
  tfAnswerD     Boolean?
  examAttempt   ExamAttempt @relation(fields: [examAttemptId], references: [id], onDelete: Cascade)
  question      Question    @relation(fields: [questionId], references: [id])

  @@index([examAttemptId])
  @@map("exam_answers")
}

model ExamSet {
  id             String   @id @default(cuid())
  title          String   @default("Untitled Exam")
  examYear       Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  pointPerMC     Float    @default(0.2)
  pointPerSA     Float    @default(0.5)
  pointPerTFItem Float    @default(0.25)

  @@map("exam_sets")
}

model ChatSession {
  id        String        @id @default(cuid())
  userId    String
  title     String        @default("New conversation")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
  @@map("chat_sessions")
}

model ChatMessage {
  id            String      @id @default(cuid())
  chatSessionId String
  role          MessageRole
  content       String
  feedback      String?
  createdAt     DateTime    @default(now())
  chatSession   ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)

  @@index([chatSessionId, createdAt])
  @@map("chat_messages")
}

model KnowledgeChunk {
  id        String                    @id @default(cuid())
  content   String
  topic     Topic
  source    String
  embedding Unsupported("vector(768)")?
  createdAt DateTime                  @default(now())

  @@map("knowledge_chunks")
}

model StudyContent {
  id         String   @id @default(cuid())
  topic      Topic
  subsection String
  title      String
  content    String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  @@unique([topic, subsection, title])
  @@index([topic, subsection])
  @@map("study_contents")
}

model StudyProgress {
  id             String   @id @default(cuid())
  userId         String
  studyContentId String
  readAt         DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, studyContentId])
  @@index([userId])
  @@map("study_progress")
}

enum UserRole {
  STUDENT
  ADMIN
}

enum QuestionFormat {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
}

enum QuestionType {
  PRACTICE
  EXAM_SET
  THPT_EXAM
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

enum Topic {
  DERIVATIVES
  INTEGRALS
  FUNCTIONS
  LIMITS
  COMPLEX_NUMBERS
  PROBABILITY
  SEQUENCES
  EXPONENTIAL_LOG
  VOLUME
  ANALYTIC_GEOMETRY
  SOLID_GEOMETRY
}

enum Difficulty {
  RECOGNITION
  COMPREHENSION
  APPLICATION
  ADVANCED
}

enum ExamMode {
  QUICK
  STANDARD
  THPT
}

enum MessageRole {
  user
  assistant
}
