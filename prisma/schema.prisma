generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  password     String
  name         String
  role         UserRole      @default(STUDENT)
  isLocked     Boolean       @default(false)
  createdAt    DateTime      @default(now())
  grade        String?
  targetScore  String?
  image        String?
  settings     Json?         @default("{}")
  updatedAt    DateTime      @updatedAt
  chatSessions     ChatSession[]
  examAttempts     ExamAttempt[]
  studyProgress    StudyProgress[]
  studyBookmarks   StudyBookmark[]
  createdQuestions Question[]      @relation("CreatedQuestions")
  ownedClassrooms  Classroom[]     @relation("ClassroomOwner")
  classMemberships ClassMember[]
  createdExamSets  ExamSet[]       @relation("ExamSetCreator")

  @@map("users")
}

model Question {
  id                 String         @id @default(cuid())
  content            String
  options            Json
  answer             String
  explanation        String
  topic              Topic
  difficulty         Difficulty
  isActive           Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  answerA            Boolean?
  answerB            Boolean?
  answerC            Boolean?
  answerD            Boolean?
  correctAnswer      String?
  format             QuestionFormat @default(MULTIPLE_CHOICE)
  statementA         String?
  statementB         String?
  statementC         String?
  statementD         String?
  imageUrl           String?
  optionAImageUrl    String?
  optionBImageUrl    String?
  optionCImageUrl    String?
  optionDImageUrl    String?
  questionType       QuestionType   @default(PRACTICE)
  statementAImageUrl String?
  statementBImageUrl String?
  statementCImageUrl String?
  statementDImageUrl String?
  createdById        String?
  createdBy          User?          @relation("CreatedQuestions", fields: [createdById], references: [id], onDelete: SetNull)
  examAnswers        ExamAnswer[]
  examSetQuestions   ExamSetQuestion[]

  @@index([topic, difficulty, isActive])
  @@index([createdById])
  @@map("questions")
}

model ExamAttempt {
  id             String       @id @default(cuid())
  userId         String
  totalScore     Float
  totalQuestions Int
  timeTakenSecs  Int
  topics         Topic[]
  mode           ExamMode     @default(STANDARD)
  startedAt      DateTime     @default(now())
  submittedAt    DateTime     @default(now())
  answers            ExamAnswer[]
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  classAssignmentId  String?
  classAssignment    ClassAssignment?  @relation(fields: [classAssignmentId], references: [id], onDelete: SetNull)

  @@index([userId, submittedAt])
  @@index([classAssignmentId])
  @@map("exam_attempts")
}

model ExamAnswer {
  id            String      @id @default(cuid())
  examAttemptId String
  questionId    String
  userAnswer    String?
  isCorrect     Boolean
  score         Float       @default(0)
  shortAnswer   String?
  tfAnswerA     Boolean?
  tfAnswerB     Boolean?
  tfAnswerC     Boolean?
  tfAnswerD     Boolean?
  examAttempt   ExamAttempt @relation(fields: [examAttemptId], references: [id], onDelete: Cascade)
  question      Question    @relation(fields: [questionId], references: [id])

  @@index([examAttemptId])
  @@map("exam_answers")
}


model ChatSession {
  id        String        @id @default(cuid())
  userId    String
  title     String        @default("New conversation")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
  @@map("chat_sessions")
}

model ChatMessage {
  id            String      @id @default(cuid())
  chatSessionId String
  role          MessageRole
  content       String
  feedback      String?
  createdAt     DateTime    @default(now())
  chatSession   ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)

  @@index([chatSessionId, createdAt])
  @@map("chat_messages")
}

model KnowledgeChunk {
  id            String                    @id @default(cuid())
  content       String
  topic         Topic
  source        String
  difficulty    Difficulty?
  subTopic      String?
  relatedTopics Topic[]
  embedding     Unsupported("vector(768)")?
  createdAt     DateTime                  @default(now())

  @@index([topic])
  @@map("knowledge_chunks")
}

model StudyContent {
  id         String   @id @default(cuid())
  topic      Topic
  subsection String
  title      String
  content    String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  @@unique([topic, subsection, title])
  @@index([topic, subsection])
  @@map("study_contents")
}

model StudyProgress {
  id             String   @id @default(cuid())
  userId         String
  studyContentId String
  readAt         DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, studyContentId])
  @@index([userId])
  @@map("study_progress")
}

model StudyBookmark {
  id         String   @id @default(cuid())
  userId     String
  topic      String
  subsection String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, topic, subsection])
  @@index([userId])
  @@map("study_bookmarks")
}

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

enum QuestionFormat {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
}

enum QuestionType {
  PRACTICE
  EXAM_SET
  THPT_EXAM
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

model Classroom {
  id          String            @id @default(cuid())
  name        String
  code        String            @unique
  description String?
  teacherId   String
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  teacher     User              @relation("ClassroomOwner", fields: [teacherId], references: [id], onDelete: Cascade)
  members     ClassMember[]
  assignments ClassAssignment[]

  @@index([teacherId])
  @@map("classrooms")
}

model ClassMember {
  id          String    @id @default(cuid())
  classroomId String
  userId      String
  joinedAt    DateTime  @default(now())
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([classroomId, userId])
  @@index([userId])
  @@map("class_members")
}

model ExamSet {
  id          String            @id @default(cuid())
  title       String
  description String?
  createdById String
  timeLimit   Int?
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  createdBy   User              @relation("ExamSetCreator", fields: [createdById], references: [id], onDelete: Cascade)
  questions   ExamSetQuestion[]
  assignments ClassAssignment[]

  @@index([createdById])
  @@map("exam_sets")
}

model ExamSetQuestion {
  id         String   @id @default(cuid())
  examSetId  String
  questionId String
  sortOrder  Int      @default(0)
  examSet    ExamSet  @relation(fields: [examSetId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([examSetId, questionId])
  @@index([examSetId, sortOrder])
  @@map("exam_set_questions")
}

model ClassAssignment {
  id           String        @id @default(cuid())
  classroomId  String
  examSetId    String
  assignedAt   DateTime      @default(now())
  dueAt        DateTime?
  maxAttempts  Int?
  isActive     Boolean       @default(true)
  classroom    Classroom     @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  examSet      ExamSet       @relation(fields: [examSetId], references: [id], onDelete: Cascade)
  examAttempts ExamAttempt[]

  @@unique([classroomId, examSetId])
  @@index([classroomId])
  @@map("class_assignments")
}

enum Topic {
  DERIVATIVES
  INTEGRALS
  FUNCTIONS
  LIMITS
  COMPLEX_NUMBERS
  PROBABILITY
  SEQUENCES
  EXPONENTIAL_LOG
  VOLUME
  ANALYTIC_GEOMETRY
  SOLID_GEOMETRY
}

enum Difficulty {
  RECOGNITION
  COMPREHENSION
  APPLICATION
  ADVANCED
}

enum ExamMode {
  QUICK
  STANDARD
  THPT
}

enum MessageRole {
  user
  assistant
}
