# ── Database (Neon PostgreSQL) ────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
DIRECT_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Authentication ───────────────────────────────────────────────────────────
NEXTAUTH_SECRET=your-random-secret-here-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# ── AI Providers (at least one required) ─────────────────────────────────────
# Gemini (primary)
GEMINI_API_KEY=

# NVIDIA (fallback)
OPENAI_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-70b-instruct
NVIDIA_VISION_MODEL=meta/llama-3.2-11b-vision-instruct
NVIDIA_TEXT_MODEL=meta/llama-3.3-70b-instruct
# Lighter model for "fast" chat mode (handles recognition/comprehension/easy-application)
NVIDIA_FAST_MODEL=meta/llama-3.1-8b-instruct

# Groq (fast fallback)
GROQ_API_KEY=
GROQ_MODEL=qwen/qwen3-32b
GROQ_FAST_MODEL=llama-3.1-8b-instant

# ── Embedding model (RAG) ─────────────────────────────────────────────────────
EMBED_MODEL=nvidia/nv-embedqa-e5-v5

# ── Rate limiting (Upstash Redis) ─────────────────────────────────────────────
# Optional. If BOTH are unset, rate limiting is automatically DISABLED (app still runs).
# Get them free at https://console.upstash.com → Redis database → REST API.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
